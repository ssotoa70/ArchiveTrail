# ArchiveTrail Environment Variables
#
# Set these in the DataEngine pipeline deployment config (VMS UI).
# Copy to .env and fill in your values for local development.

# --- VAST S3 (source storage) ---
S3_ENDPOINT=https://your-vast-vip.example.com
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- VAST Database ---
VAST_DB_ENDPOINT=https://your-vast-vip.example.com
VAST_DB_ACCESS_KEY=
VAST_DB_SECRET_KEY=
VAST_DB_BUCKET=archive-trail-db
VAST_DB_SCHEMA=archive/lineage

# --- VAST Catalog ---
VAST_CATALOG_BUCKET=vast-big-catalog-bucket
VAST_CATALOG_SCHEMA=catalog
VAST_CATALOG_TABLE=catalog_table

# --- VAST Cluster ---
VAST_CLUSTER_NAME=my-vast-cluster

# --- AWS S3 (offload destination) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
