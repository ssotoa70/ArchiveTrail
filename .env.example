# ArchiveTrail Environment Variables
#
# These are used by the DataEngine functions and CLI.
# Copy to .env and fill in your values.

# VAST cluster S3 endpoint
VAST_S3_ENDPOINT=https://vip-pool.vast.local

# VAST cluster name (for genealogy metadata)
VAST_CLUSTER_NAME=vast-cluster-01

# AWS credentials (or use IAM role on the K8s nodes)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# VAST DB connection (used by vastdb SDK)
VASTDB_ENDPOINT=https://vms.vast.local
VASTDB_ACCESS_KEY=
VASTDB_SECRET_KEY=
